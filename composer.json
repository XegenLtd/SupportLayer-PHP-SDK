{
    "name": "supportlayer/php-sdk",
    "description": "Official PHP SDK for the SupportLayer REST API",
    "type": "library",
    "license": "MIT",
    "keywords": ["supportlayer", "helpdesk", "ticketing", "api", "sdk"],
    "require": {
        "php": ">=8.1",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "SupportLayer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SupportLayer\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable"
}
